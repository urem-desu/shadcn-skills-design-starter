# Figma REST API — used by `npm run tokens:fetch` / `tokens:sync`
# Copy this file to `.env.local` (gitignored) and fill in the real value.

# Personal access token from Figma → Settings → Security → Personal access tokens.
# Needs the `file_variables:read` scope. Starts with `figd_`.
# NOTE: the Variables REST API is a Figma Enterprise feature.
FIGMA_PERSONAL_ACCESS_TOKEN=figd_your_token_here

# File to read variables from (defaults to the project file if omitted).
FIGMA_FILE_KEY=UOQqHNISgc7bbc8yWt8Vj8

# Optional — where the fetched export JSON is written
# (default: figma/variables-export.json)
# FIGMA_EXPORT=figma/variables-export.json
